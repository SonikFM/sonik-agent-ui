# Disabled unless explicitly enabled. Protect the deployment with Vercel Authentication.
DEV_WORKBENCH_ENABLED=false

# The server owns repository selection. Browser requests cannot override these values.
DEV_WORKBENCH_REPOSITORY_URL=https://github.com/sonikfm/sonik-agent-ui.git
DEV_WORKBENCH_REPOSITORY_REVISION=main
DEV_WORKBENCH_AGENT_API_ORIGIN=https://sonik-agent-ui.liam-trampota.workers.dev
PUBLIC_DEV_WORKBENCH_ALLOWED_HOST_ORIGINS=https://*.workers.dev,https://*.sonik.fm
DEV_WORKBENCH_ORGANIZATION_ID=sonikfm

# Required whenever the workbench is enabled. The browser keeps these in its
# native HTTP authentication session; they never enter page state or context.
DEV_WORKBENCH_BASIC_AUTH_USERNAME=
DEV_WORKBENCH_BASIC_AUTH_PASSWORD=

# Sandbox lifecycle and preview process.
DEV_WORKBENCH_TIMEOUT_MS=2700000

# Optional: read-write sandbox checkouts for booking-service and/or amplify, alongside the
# primary agent-ui repo above. Leave a profile's two vars unset to skip it entirely — the
# workbench is unaffected. If ANY profile below is set, the GitHub App vars are required too
# (config fails closed rather than cloning without auth). Auth for these profiles rides a
# short-lived, repo-scoped GitHub App installation token delivered into the sandbox via a
# git-credentials file — never a URL, env var, or command argv.
DEV_WORKBENCH_BOOKING_SERVICE_REPOSITORY_URL=
DEV_WORKBENCH_BOOKING_SERVICE_REPOSITORY_REVISION=
DEV_WORKBENCH_AMPLIFY_REPOSITORY_URL=
DEV_WORKBENCH_AMPLIFY_REPOSITORY_REVISION=

# Required when any additional repository profile above is configured. Register a GitHub App
# with contents:read/write on the booking-service and amplify repos, install it on those repos,
# and record its numeric installation ID. The private key is server-side only — never commit a
# real value, never expose it to the browser, never pass it as a wrangler var with a value.
DEV_WORKBENCH_GITHUB_APP_ID=
DEV_WORKBENCH_GITHUB_APP_PRIVATE_KEY=
DEV_WORKBENCH_GITHUB_APP_INSTALLATION_ID=

# The SDK uses VERCEL_OIDC_TOKEN automatically in Vercel deployments. For local
# development run `vercel link && vercel env pull` to obtain a short-lived token.
VERCEL_OIDC_TOKEN=
